# Advanced Military Aircraft Tracker Bot Configuration
# Copy this file to .env and fill in your values

# ========== Telegram Configuration ==========
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your channel ID (with @ symbol for public channels or -100 for private channels)
TELEGRAM_CHANNEL_ID=your_channel_id_here

# Your Telegram user ID (for admin commands and reports)
TELEGRAM_ADMIN_ID=7717672777

# ========== Gemini AI Configuration ==========
# Primary Gemini API key (required)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_primary_gemini_api_key_here

# Secondary API key (optional, for redundancy)
GEMINI_API_KEY_2=your_secondary_gemini_api_key_here

# Tertiary API key (optional, for redundancy)
GEMINI_API_KEY_3=your_tertiary_gemini_api_key_here

# ========== Flight Tracking Configuration ==========
# Polling interval in seconds (minimum: 10, recommended: 30)
POLL_INTERVAL=30

# ========== Logging Configuration ==========
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=military_tracker.log

# ========== Database Configuration ==========
# Database file path
DATABASE_FILE=military_aircraft.db

# ========== Environment Configuration ==========
# Environment: development, production
ENVIRONMENT=production

# ========== Advanced Configuration (Optional) ==========
# Minimum altitude in meters (flights below this will be ignored)
MIN_ALTITUDE=100

# Maximum altitude in meters (flights above this will be ignored)
MAX_ALTITUDE=50000

# Enable/disable USA airspace filtering
FILTER_USA_AIRSPACE=true

# Enable/disable AI analysis caching
ENABLE_AI_CACHING=true

# AI analysis cache TTL in hours
AI_CACHE_TTL=72

# Maximum notifications per hour
MAX_NOTIFICATIONS_PER_HOUR=50

# ========== Security Configuration ==========
# Enable/disable input validation
ENABLE_INPUT_VALIDATION=true

# Enable/disable rate limiting
ENABLE_RATE_LIMITING=true

# Maximum requests per minute
MAX_REQUESTS_PER_MINUTE=60

# ========== Performance Configuration ==========
# Maximum worker threads
MAX_WORKER_THREADS=10

# Maximum async tasks
MAX_ASYNC_TASKS=50

# Connection pool size
CONNECTION_POOL_SIZE=20

# ========== Notification Configuration ==========
# Enable/disable rich formatting
ENABLE_RICH_FORMATTING=true

# Enable/disable emojis in messages
ENABLE_EMOJIS=true

# Enable/disable links in messages
ENABLE_LINKS=true

# Minimum strategic importance for notifications (1-10)
MIN_STRATEGIC_IMPORTANCE=3

# Minimum threat level for notifications (کم, متوسط, بالا, بحرانی)
MIN_THREAT_LEVEL=کم

# ========== Geographic Configuration ==========
# Enable/disable geographic filtering
ENABLE_GEOGRAPHIC_FILTERING=true

# Custom bounding box for filtering (lat_min, lat_max, lon_min, lon_max)
# Leave empty to use default USA bounding box
CUSTOM_BOUNDING_BOX=

# ========== Backup Configuration ==========
# Enable/disable automatic backups
ENABLE_AUTO_BACKUP=true

# Backup interval in hours
BACKUP_INTERVAL_HOURS=6

# Maximum number of backups to keep
MAX_BACKUPS=10

# ========== Monitoring Configuration ==========
# Enable/disable system monitoring
ENABLE_MONITORING=true

# Enable/disable performance metrics
ENABLE_METRICS=true

# Enable/disable health checks
ENABLE_HEALTH_CHECKS=true